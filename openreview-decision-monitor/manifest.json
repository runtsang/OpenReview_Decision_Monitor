{
  "manifest_version": 3,
  "name": "OpenReview Decision Monitor",
  "version": "1.0.0",
  "description": "Monitor OpenReview paper decisions and notify authors via desktop notifications, EmailJS, or Gmail.",
  "minimum_chrome_version": "116",
  "permissions": [
    "alarms",
    "cookies",
    "identity",
    "identity.email",
    "notifications",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://openreview.net/*",
    "https://api2.openreview.net/*",
    "https://accounts.google.com/*",
    "https://gmail.googleapis.com/*",
    "https://api.emailjs.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://openreview.net/forum*",
        "https://openreview.net/group*"
      ],
      "js": [
        "lib/shared.js",
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "OpenReview Decision Monitor",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
